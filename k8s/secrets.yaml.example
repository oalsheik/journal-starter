# secrets.yaml.example
# This file shows the required keys for the Kubernetes secrets used by this app.
# NEVER commit real values. Create secrets directly in the cluster using the
# commands below, or let the CI/CD pipeline create them via GitHub Secrets.
#
# -----------------------------------------------------------------------
# 1) App environment variables (injected into the container via envFrom)
# -----------------------------------------------------------------------
#
#   kubectl create secret generic journal-api-secrets \
#     --from-literal=DATABASE_URL="postgresql://user:password@host:5432/dbname" \
#     --from-literal=OPENAI_API_KEY="sk-..." \
#     --from-literal=OPENAI_BASE_URL="https://..." \
#     --from-literal=OPENAI_MODEL="gpt-4o" \
#     --save-config --dry-run=client -o yaml | kubectl apply -f -
#
# Required keys:
#   DATABASE_URL      - Full PostgreSQL connection string
#   OPENAI_API_KEY    - API key for OpenAI-compatible endpoint
#   OPENAI_BASE_URL   - Base URL for OpenAI-compatible endpoint
#   OPENAI_MODEL      - Model name to use (e.g. gpt-4o)
#
# -----------------------------------------------------------------------
# 2) ACR image pull secret (used by Kubernetes to pull the container image)
# -----------------------------------------------------------------------
#
#   kubectl create secret docker-registry acr-secret \
#     --docker-server=<your-registry>.azurecr.io \
#     --docker-username="<acr-username>" \
#     --docker-password="<acr-password>" \
#     --save-config --dry-run=client -o yaml | kubectl apply -f -
#
# Required keys:
#   --docker-server    - ACR login server (e.g. l2capi.azurecr.io)
#   --docker-username  - ACR username
#   --docker-password  - ACR password or token
#
# -----------------------------------------------------------------------
# GitHub Secrets required for CI/CD (set in repo Settings → Secrets)
# -----------------------------------------------------------------------
#   ACR_USERNAME       - Azure Container Registry username
#   ACR_PASSWORD       - Azure Container Registry password
#   AKS_RESOURCE_GROUP - Resource group containing the AKS cluster
#   AKS_CLUSTER_NAME   - AKS cluster name
#   AZURE_CREDENTIALS  - Azure service principal JSON (az ad sp create-for-rbac)
#   DATABASE_URL       - PostgreSQL connection string
#   OPENAI_API_KEY     - OpenAI API key
#   OPENAI_BASE_URL    - OpenAI base URL
#   OPENAI_MODEL       - OpenAI model name
